# Database — defaults to SQLite if not set
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/wbms
# DATABASE_URL=sqlite:///./wbms.db

# MQTT broker (published by the master ESP32)
MQTT_BROKER=64.23.174.210
MQTT_PORT=1883
MQTT_TOPIC=bms/data
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173

# BMS topology
CONNECTED_CELLS=3
PARALLEL_COUNT=1

# Google OAuth — Web Client ID from Google Cloud Console
# Must match VITE_GOOGLE_CLIENT_ID on the frontend
GOOGLE_CLIENT_ID=
